# =================================================================
# CLIENT-SIDE (VITE_ prefix) — se inyectan en BUILD TIME en el bundle JS.
# Tienen que estar presentes ANTES de correr `npm run build` o quedan undefined.
# Cópialo a `.env` (sin `.example`) y rellena con valores reales.
# =================================================================

# URL pública del proyecto Supabase (Settings → API → Project URL).
# Misma URL que SUPABASE_URL del server pero expuesta al cliente.
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxx.supabase.co

# Anon/public key de Supabase (Settings → API → Project API keys → anon public).
# Es pública por diseño: el cliente la usa con RLS para queries no privilegiadas.
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...

# Publishable key (opcional, solo si tu cliente Supabase la usa).
# Si en src/integrations/supabase/client.ts NO aparece, déjala vacía o coméntala.
# VITE_SUPABASE_PUBLISHABLE_KEY=

# =================================================================
# SERVER-SIDE — NO van aquí, van como Cloudflare secrets:
#   npx wrangler secret put SUPABASE_URL --config dist/server/wrangler.json
#   npx wrangler secret put SUPABASE_SERVICE_ROLE_KEY --config dist/server/wrangler.json
#   npx wrangler secret put GOOGLE_API_KEY --config dist/server/wrangler.json
#   npx wrangler secret put ANTHROPIC_API_KEY --config dist/server/wrangler.json
#   npx wrangler secret put META_ACCESS_TOKEN --config dist/server/wrangler.json
#   npx wrangler secret put META_IG_USER_ID --config dist/server/wrangler.json
#   npx wrangler secret put META_FB_PAGE_ID --config dist/server/wrangler.json
# =================================================================
