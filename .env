# Supabase removed — configure the following in .dev.vars for local dev
# and via `wrangler secret put` for production.
#
# DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require
# R2_PUBLIC_URL_BIBLIOTECA=https://pub-xxx.r2.dev/biblioteca
# R2_PUBLIC_URL_CONTENIDO=https://pub-xxx.r2.dev/contenido-propio
# ANTHROPIC_API_KEY=
# LOVABLE_API_KEY=
# HIGGSFIELD_API_KEY=
# HIGGSFIELD_API_SECRET=
# MAKE_WEBHOOK_URL=
